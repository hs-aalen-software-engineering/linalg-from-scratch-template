# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/
.uv/

# C++ build — matches cpp/build, cpp/build-O0, cpp/build-O2, cpp/build-O3, ...
cpp/build*/
cpp/_deps/
*.o
*.obj
*.a
*.so
*.dylib
*.exe

# Editor / OS
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Claude Code session metadata
.claude/

# Generated benchmark artifacts (CSVs are hardware-specific; plots are derived).
# If you want to commit your run intentionally, use `git add -f`.
results/*.csv
results/*.png
results/*.svg
!results/.gitkeep

# Notebook checkpoints
.ipynb_checkpoints/
